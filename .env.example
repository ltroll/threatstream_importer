THREATSTREAM_USERNAME=you@example.com
THREATSTREAM_API_KEY=replace-with-your-api-key
THREATSTREAM_BASE_URL=https://api.threatstream.com

# Optional defaults used by the CLI when matching arguments are omitted.
THREATSTREAM_CLASSIFICATION=private
THREATSTREAM_CONFIDENCE=60
THREATSTREAM_SEVERITY=high
THREATSTREAM_ALLOW_UNRESOLVED=true
THREATSTREAM_SOURCE_CONFIDENCE_WEIGHT=100
THREATSTREAM_TAG_TLP=red

# Optional for UI-backed transform calls if API key auth is not accepted by the endpoint.
THREATSTREAM_SESSION_COOKIE=
THREATSTREAM_CSRF_TOKEN=

# CISA KEV watcher settings.
KEV_URL=https://raw.githubusercontent.com/cisagov/kev-data/develop/known_exploited_vulnerabilities.json
KEV_WATCH_INTERVAL_SECONDS=600
KEV_WATCHER_STATE_FILE=kev_watcher_state.json
KEV_TRUSTED_CIRCLE_ID=310
KEV_TAG_NAME=cisa_kev
# Optional comma-separated override for org-specific tags.
# Lowercase kev_tag_override is also supported.
KEV_TAG_OVERRIDE=
KEV_TAG_TLP=red

# Threat Model API paths. Override these if your ThreatStream tenant uses different paths.
THREATSTREAM_THREAT_MODEL_SEARCH_PATH=/api/v1/threat_model_search/
THREATSTREAM_VULNERABILITY_PATH=/api/v1/vulnerability/
THREATSTREAM_VULNERABILITY_TAG_PATH_TEMPLATE=/api/v1/vulnerability/{id}/tag/

# NVD sync settings.
NVD_CVE_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
# Optional: only set if this NVD use case should search/share with a trusted circle.
NVD_TRUSTED_CIRCLE_ID=
# Optional: set this so NVD sync only updates vulnerability models owned by your org.
# Without this, exact CVE matches in the trusted circle may be updated.
NVD_ORGANIZATION_ID=
NVD_TAG_NAME=nvd_sync
# Optional comma-separated override for org-specific NVD sync tags.
# Lowercase nvd_tag_override is also supported.
NVD_TAG_OVERRIDE=
NVD_TAG_TLP=red

# Vulnerability-management integration transform settings.
THREATSTREAM_TRANSFORM_PATH=/api/v1/integration_package/transform/
THREATSTREAM_VULN_TRANSFORM_ID=4425
